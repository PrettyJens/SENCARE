<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sencare Portal</title>
    
    <link rel="stylesheet" href="style.css">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>

    <div id="login-screen" class="page-wrapper">
        <span class="outer-brand-label">SENCARE</span>
        <main class="login-container">
            <section class="brand-section">
                <div class="brand-title-wrap">
                    <div class="logo-placeholder-container">
                        <img src="logo.png" alt="Logo Space" class="brand-logo-img">
                    </div>
                    <div class="brand-text-group">
                        <h1 class="brand-main-title">SENCARE</h1>
                        <p class="brand-subtitle">STAFF</p>
                    </div>
                </div>
            </section>

            <div class="form-card-wrapper">
                <section class="form-section">
                    <h2 class="form-title">SENCARE</h2>
                    <form id="login-form" class="login-form">
                        <div class="input-group">
                            <label for="osca-id">OSCA ID Number:</label>
                            <input type="text" id="osca-id" required>
                        </div>
                        <div class="input-group">
                            <label for="password">Password:</label>
                            <input type="password" id="password" required>
                        </div>
                        <button type="submit" class="login-btn">Login</button>
                    </form>
                    <div class="form-links">
                        <a href="#">Forgot Password</a>
                        <span class="divider">|</span>
                        <a href="#">Need Help?</a>
                    </div>
                    <footer class="form-footer">
                        <p>2026 Local Government Unit</p>
                        <p>Office of Senior Citizens Affairs (OSCA)</p>
                    </footer>
                </section>
            </div>
        </main>
    </div>

    <div id="dashboard-screen" class="dashboard-container hidden">
        <aside class="sidebar" id="sidebar-panel">
            <div class="sidebar-header">
                <h2 class="sidebar-brand-text">SENCARE</h2>
                <div class="menu-toggle" id="hamburger-trigger">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            </div>
            
            <nav class="sidebar-nav">
                <a href="#" class="nav-item active" data-target="dashboard-content">
                    <span class="nav-icon">📊</span>
                    <span class="nav-text">Dashboard</span>
                </a>
                <a href="#" class="nav-item" data-target="request-content">
                    <span class="nav-icon">📋</span>
                    <span class="nav-text">Request Management</span>
                </a>
                <a href="#" class="nav-item" data-target="senior-content">
                    <span class="nav-icon">👴</span>
                    <span class="nav-text">Senior Citizen Info</span>
                </a>
                <a href="#" class="nav-item" data-target="priority-content">
                    <span class="nav-icon">🔷</span>
                    <span class="nav-text">Priority Monitoring</span>
                </a>
                <a href="#" class="nav-item" data-target="home-content">
                    <span class="nav-icon">🏠</span>
                    <span class="nav-text">Home Visit</span>
                </a>
                <a href="#" class="nav-item" data-target="updates-content">
                    <span class="nav-icon">🔔</span>
                    <span class="nav-text">Updates and Notifications</span>
                </a>
                <a href="#" class="nav-item" data-target="photo-content">
                    <span class="nav-icon">📷</span>
                    <span class="nav-text">Photo Verification</span>
                </a>
            </nav>
            
            <div class="sidebar-footer">
                <p class="user-role-text">Staff</p>
            </div>
        </aside>

        <main class="main-content">
            <div id="dashboard-content" class="tab-content">
                <header class="content-header">
                    <h1>Good Afternoon, Staff</h1>
                    <p>Here's What's Happening Today!</p>
                </header>
                <section class="metrics-grid">
                    <div class="metric-card"><span class="count">248</span><span class="label">Requests</span></div>
                    <div class="metric-card"><span class="count">19,856</span><span class="label">Seniors</span></div>
                </section>
            </div>
            <div id="request-content" class="tab-content hidden"><h1>Request Management Panel</h1></div>
            <div id="senior-content" class="tab-content hidden"><h1>Senior Citizen Information</h1></div>
            <div id="priority-content" class="tab-content hidden"><h1>Priority Monitoring</h1></div>
            <div id="home-content" class="tab-content hidden"><h1>Home Visit Schedules</h1></div>
            <div id="updates-content" class="tab-content hidden"><h1>Updates & Live Notifications</h1></div>
            <div id="photo-content" class="tab-content hidden"><h1>Photo Verification Desk</h1></div>
        </main>
    </div>

    <script src="script.js"></script>
</body>
</html>
